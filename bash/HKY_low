# HKY low
%include dna-defaults

MeanSubstitution = 0.1 
# No substitutions
TheInsertThreshold = 0.0 
TheDeleteThreshold = 0.0 
Relatedness = 20

TheDNAmodel = "HKY" 
TheAlphabet = "ACGT"

# Base Frequencies (Should sum to 1.0)
# Example: Higher AT content
TheFreq = [.30, .20, .20, .30] 

# Transition/Transversion Bias
# 1.0 = equal rates; > 1.0 = more transitions
TransitionBias = 1.0 


StdOut = False
#SequenceSuffix = ".fas"
AlignmentFormat = "PHYLIP"
AlignmentSuffix = ".phy"
TreeSuffix = ".tree"
SequenceOutputLen = 500
ChooseFromLeaves = True

